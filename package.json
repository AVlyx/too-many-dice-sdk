{
  "name": "too-many-dice",
  "version": "0.1.6",
  "description": "TypeScript SDK for TooManyDice online game API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run --exclude src/__tests__/integration.test.ts",
    "test:watch": "vitest --exclude src/__tests__/integration.test.ts",
    "test:integration": "vitest run src/__tests__/integration.test.ts"
  },
  "license": "MIT",
  "author": "Anton Van Cleemput",
  "repository": {
    "type": "git",
    "url": "https://github.com/AVlyx/too-many-dice-sdk"
  },
  "keywords": [
    "dice",
    "tabletop",
    "game",
    "couch games",
    "sdk"
  ],
  "dependencies": {
    "partysocket": "^1.1.16"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.3.0",
    "sharp": "^0.34.5",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.1"
  }
}
